{
  "schema_version": 13,
  "playwright_version": "1.61.1",
  "review_batch_size": 4,
  "impact_scopes": ["direct", "neighbors", "full"],
  "content_change_categories": ["text", "image", "structure", "style", "runtime"],
  "profiles": {
    "normal": {
      "viewport": [1920, 1080],
      "visual_viewport": [1920, 1080],
      "screenshot": [1920, 1080],
      "zoom": 1,
      "scale_mode": "none",
      "device_pixel_ratio": 1
    },
    "short": {
      "viewport": [1366, 650],
      "visual_viewport": [1366, 650],
      "screenshot": [1366, 650],
      "zoom": 1,
      "scale_mode": "none",
      "device_pixel_ratio": 1
    },
    "zoom150": {
      "viewport": [1920, 1080],
      "visual_viewport": [1280, 720],
      "screenshot": [1920, 1080],
      "zoom": 1.5,
      "scale_mode": "browser-page",
      "device_pixel_ratio": 1
    },
    "tablet": {
      "viewport": [1024, 768],
      "visual_viewport": [1024, 768],
      "screenshot": [1024, 768],
      "zoom": 1,
      "scale_mode": "none",
      "device_pixel_ratio": 1
    },
    "mobile": {
      "viewport": [390, 844],
      "visual_viewport": [390, 844],
      "screenshot": [390, 844],
      "zoom": 1,
      "scale_mode": "none",
      "device_pixel_ratio": 1
    }
  },
  "base_profiles": ["normal", "short", "zoom150"],
  "responsive_profiles": ["tablet", "mobile"],
  "checks_by_change": {
    "all": ["crop", "aspect_ratio", "resolution", "content_match", "completion", "overflow", "occlusion", "text", "text_bounds", "contrast", "density", "controls"],
    "text": ["text", "text_bounds", "contrast", "density"],
    "image": ["crop", "aspect_ratio", "resolution", "content_match", "completion"],
    "navigation": ["controls"]
  },
  "automation_checks_by_change": {
    "all": ["text_bounds", "font_integrity", "contrast", "container_density", "controls", "image_geometry"],
    "text": ["text_bounds", "font_integrity", "contrast", "container_density"],
    "image": ["image_geometry"],
    "navigation": ["controls"]
  },
  "cross_review_routes": {
    "visual_critical": true,
    "automation_warning": true,
    "identity_required": true
  },
  "squint_review_checks": [
    "focal_hierarchy",
    "emphasis_range",
    "deck_rhythm",
    "color_density_balance"
  ],
  "slide_variety": {
    "skeleton_similarity_threshold": 0.9,
    "minimum_structural_elements": 8,
    "exempt_slide_kinds": ["section", "divider", "chapter", "interstitial", "transition", "quote"],
    "opt_out_attribute": "data-variety-ok"
  },
  "python_dependencies": [
    {
      "module": "PIL",
      "package": "pillow",
      "minimum_version": "9.0.0",
      "required": false,
      "purpose": "fast capture pixel metrics in validate_visual_review.py",
      "fallback": "built-in PNG decoder producing identical metrics at roughly 3x the cost"
    }
  ],
  "time_budgets": {
    "slide_range": [20, 25],
    "full": {
      "total_minutes": 70,
      "phases": {
        "prepare": 15,
        "primary-review": 25,
        "verify": 3,
        "finalize-prepare": 5,
        "final-review": 18,
        "finalize-verify": 4
      }
    },
    "quick": {
      "total_minutes": 15,
      "phases": {
        "draft": 15
      }
    }
  }
}
